# ===================================
# SERVER CONFIGURATION
# ===================================
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# ===================================
# DATABASE (PostgreSQL)
# ===================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=globaldisparos
DB_USER=postgres
DB_PASSWORD=postgres
DB_DIALECT=postgres
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000

# ===================================
# JWT CONFIGURATION
# ===================================
JWT_SECRET=CHANGE_THIS_IN_PRODUCTION_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_ALSO
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===================================
# REDIS (Cache + Session Store)
# ===================================
# ⚠️  Opcional - pode ser comentado se não estiver usando Docker/Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ===================================
# CORS & FRONTEND
# ===================================
FRONTEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,https://yourdomain.com
CORS_CREDENTIALS=true

# ===================================
# RATE LIMITING
# ===================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ===================================
# SECURITY
# ===================================
HELMET_ENABLED=true
SECURITY_HEADERS_ENABLED=true
CSRF_PROTECTION_ENABLED=true

# ===================================
# WHATSAPP ADAPTER
# ===================================
WHATSAPP_ADAPTER=baileys
AUTH_SESSIONS_DIR=./auth_sessions
# WHATSAPP_ADAPTER=evolution
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=

# ===================================
# ANTI-BAN SYSTEM
# ===================================
ANTI_BAN_NEW_ACCOUNT_DAYS=7
ANTI_BAN_MEDIUM_ACCOUNT_DAYS=30
ANTI_BAN_NEW_DAILY_LIMIT=50
ANTI_BAN_MEDIUM_DAILY_LIMIT=150
ANTI_BAN_OLD_DAILY_LIMIT=500
ANTI_BAN_NEW_DELAY_MIN=15
ANTI_BAN_NEW_DELAY_MAX=45
ANTI_BAN_MEDIUM_DELAY_MIN=8
ANTI_BAN_MEDIUM_DELAY_MAX=20
ANTI_BAN_OLD_DELAY_MIN=3
ANTI_BAN_OLD_DELAY_MAX=10
ANTI_BAN_BURST_MIN=5
ANTI_BAN_BURST_MAX=20
ANTI_BAN_PAUSE_MIN=120
ANTI_BAN_PAUSE_MAX=300
ANTI_BAN_START_HOUR=9
ANTI_BAN_END_HOUR=21
ANTI_BAN_ERROR_THRESHOLD=70

# ===================================
# SENTRY (Error Tracking)
# ===================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENABLED=false

# ===================================
# BACKUPS
# ===================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=

# ===================================
# FILE STORAGE
# ===================================
UPLOADS_DIR=./uploads
MAX_FILE_SIZE=10485760

# ===================================
# ADMIN DEFAULT (Setup Only)
# ===================================
ADMIN_EMAIL=admin@domain.com
ADMIN_PASSWORD=Admin@123456
