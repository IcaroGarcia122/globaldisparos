# === AMBIENTE DE TESTES ===
NODE_ENV=test

# === SERVIDOR ===
PORT=3001
HOST=localhost

# === BANCO DE DADOS (usar BD separada para testes) ===
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=globaldisparos_test

# === JWT ===
JWT_SECRET=test-secret-key-for-vitest-only-change-in-production
JWT_EXPIRY=24h

# === REDIS (opcional para testes) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === SENTRY (desativado em testes) ===
SENTRY_DSN=

# === LOGGING ===
LOG_LEVEL=debug
LOG_FORMAT=json

# === TIMEOUT ===
VITEST_TIMEOUT=10000
