  "endpoints_api": {
    "disparador": {
      "POST /api/disparador/iniciar": {
        "descricao": "Iniciar campanha de disparo",
        "params": ["instanceId", "groupIds[]", "message", "interval", "campaignName"],
        "response": "{ campaignId, totalContacts, estimatedDuration }"
      },
      "GET /api/disparador/:id": {
        "descricao": "Obter status da campanha",
        "response": "{ status, totalContacts, messagesSent, messagesFailed, progress, ... }"
      },
      "POST /api/disparador/:id/pausar": {
        "descricao": "Pausar campanha"
      },
      "POST /api/disparador/:id/retomar": {
        "descricao": "Retomar campanha pausada"
      },
      "POST /api/disparador/:id/parar": {
        "descricao": "Parar campanha"
      },
      "GET /api/disparador/:id/metricas": {
        "descricao": "Obter métricas detalhadas"
      }
    }
  },

  "socket_io_events": {
    "campanha:progresso": {
      "descricao": "Atualização de progresso (a cada mensagem)",
      "dados": ["campaignId", "sent", "failed", "remaining", "percentual", "elapsedSeconds", "estimatedTotal", "velocidade"]
    },
    "campanha:concluida": {
      "descricao": "Campanha finalizada",
      "dados": ["campaignId", "totalSent", "totalFailed", "successRate", "duration"]
    },
    "campanha:erro": {
      "descricao": "Erro durante execução",
      "dados": ["campaignId", "error"]
    }
  },

